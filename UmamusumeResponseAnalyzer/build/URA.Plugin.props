<Project>
  <!--
    URA.Plugin.props — 默认插件属性。和 URA.Plugin.targets 配对使用。
    插件作者在 csproj 顶部 import 这个 props 文件即可获得：
      - 默认 net10.0
      - 默认开启 Nullable + ImplicitUsings
      - 一组 <Plugin*> 元数据属性的默认值

    具体的 build/publish 行为（manifest.json 生成、打 zip、上传到 URACloud）由
    URA.Plugin.targets 实现，会在导入 props 之后由插件 csproj 自行引入。
  -->
  <PropertyGroup>
    <TargetFramework Condition="'$(TargetFramework)' == ''">net10.0</TargetFramework>
    <ImplicitUsings Condition="'$(ImplicitUsings)' == ''">enable</ImplicitUsings>
    <Nullable Condition="'$(Nullable)' == ''">enable</Nullable>
    <GenerateAssemblyInfo Condition="'$(GenerateAssemblyInfo)' == ''">true</GenerateAssemblyInfo>

    <!--
      插件作者可覆盖的元数据属性，可在 csproj 的 <PropertyGroup> 里设置：
        <PluginInternalName>          assembly 名（默认 $(AssemblyName)）。必须【等于程序集名】:宿主全程以程序集名为插件身份键(安装/热重载/更新匹配),改成别的会导致装后被误判"需重启"、更新检测失效
        <PluginDisplayName>           中文显示名（默认使用 $(AssemblyName)）
        <PluginAuthor>                作者，多人用 "&amp;" 分隔（默认使用 $(Authors)）
        <PluginDescription>           简短描述
        <PluginCategory>              分类字符串。空字符串在客户端(宿主/前端)按 "其他" 归类显示
        <PluginChangelog>             本次发布的 changelog（默认空）
        <PluginRepositoryUrl>         源码仓库 URL（默认空）
        <PluginHomepage>              主页 URL（默认空）
        <PluginTargets>               目标游戏版本，逗号分隔（如 "Cygames,Komoe"，默认空=两个都支持）
        <PluginDependencies>          依赖插件 InternalName，逗号分隔（默认空）

      构建产物（manifest.json + zip）会自动放在 OutDir 旁边，管理员手动收走并通过
      URACloud 的 POST /Plugins/{name}/versions 上传——这里不再提供自动 publish 目标。
    -->
    <PluginInternalName Condition="'$(PluginInternalName)' == ''">$(AssemblyName)</PluginInternalName>
    <PluginDisplayName Condition="'$(PluginDisplayName)' == ''">$(AssemblyName)</PluginDisplayName>
    <PluginAuthor Condition="'$(PluginAuthor)' == '' and '$(Authors)' != ''">$(Authors)</PluginAuthor>
    <PluginAuthor Condition="'$(PluginAuthor)' == ''">unknown</PluginAuthor>
    <PluginDescription Condition="'$(PluginDescription)' == ''">$(Description)</PluginDescription>
    <PluginCategory Condition="'$(PluginCategory)' == ''"></PluginCategory>
    <PluginChangelog Condition="'$(PluginChangelog)' == ''"></PluginChangelog>
    <PluginRepositoryUrl Condition="'$(PluginRepositoryUrl)' == ''"></PluginRepositoryUrl>
    <PluginHomepage Condition="'$(PluginHomepage)' == ''"></PluginHomepage>
    <PluginTargets Condition="'$(PluginTargets)' == ''"></PluginTargets>
    <PluginDependencies Condition="'$(PluginDependencies)' == ''"></PluginDependencies>

    <!-- 让 GenerateUraPluginManifest 默认随 Build 一起跑；可设为 false 关闭 -->
    <GenerateUraPluginManifestOnBuild Condition="'$(GenerateUraPluginManifestOnBuild)' == ''">true</GenerateUraPluginManifestOnBuild>
    <PackageUraPluginOnBuild Condition="'$(PackageUraPluginOnBuild)' == ''">true</PackageUraPluginOnBuild>
    <!--
      $(UraPluginManifestPath) / $(UraPluginPackagePath) 的默认值依赖 $(OutDir)，
      该变量直到 SDK 的 Microsoft.NET.Sdk.Common.props 之后才被设置，所以默认值
      放在 URA.Plugin.targets 里（属于 SDK 之后的导入阶段）做。
    -->

    <!--
      第三方 NuGet 依赖随 zip 分发：targets 会把整个 OutDir 打成 zip，所以插件若依赖第三方包
      （如 CsvHelper / MathNet / AnyDiff），要让其运行时 DLL 落到 OutDir。推荐写法：
        · 本工程加 <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>（拷依赖闭包，含传递依赖）
        · 在【所有】指向 host / 兄弟插件的 <ProjectReference> 上加 <ExcludeAssets>runtime</ExcludeAssets>
          （它们由宿主在运行时提供、不应打进包；否则 Spectre/MessagePack/… 会被一并打进 zip，臃肿且可能在插件 ALC 里重复加载）
      不要用 GeneratePathProperty + 手写 <None Include="$(Pkg…)\lib\netX\X.dll">：硬编码 lib 路径易碎、且漏掉包自己的传递依赖。
      此属性【不默认开启】：多数插件无第三方依赖，默认开反而会要求每个插件都加 ExcludeAssets 才不泄漏 host 依赖。
    -->
  </PropertyGroup>
</Project>
